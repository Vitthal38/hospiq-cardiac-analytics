# AWS Credentials — NEVER commit real .env file
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1

# S3
S3_BUCKET=hospiq-cardiac-data-935140613339
S3_RAW_PREFIX=raw/
S3_PROCESSED_PREFIX=processed/

# RDS PostgreSQL
RDS_HOST=your-rds-endpoint.ap-south-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=hospiq
RDS_USERNAME=hospiq_admin
RDS_PASSWORD=your_password_here
